// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PackageCategory {
  SPONSORSHIP
  SIGNAGE
  GOLF
  DINNER
  DONATION
}

enum RegistrationStatus {
  PENDING
  PAID
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum DonationStatus {
  PENDING
  PAID
  FAILED
}

enum GalleryCategory {
  SOCIAL
  EXECUTIVE
  ONE_ON_ONE
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Event {
  id            String         @id @default(cuid())
  name          String
  date          DateTime
  location      String
  packages      Package[]
  registrations Registration[]
  createdAt     DateTime       @default(now())
}

model Package {
  id                String          @id @default(cuid())
  eventId           String
  name              String
  description       String
  category          PackageCategory
  price             Int
  earlyBirdPrice    Int?
  earlyBirdDeadline DateTime?
  maxSlots          Int?
  exclusive         Boolean         @default(false)
  registrations     Registration[]
  createdAt         DateTime        @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, name])
  @@index([eventId])
  @@index([category])
}

model Registration {
  id             String             @id @default(cuid())
  eventId        String
  packageId      String
  name           String
  email          String
  phone          String
  address        String
  city           String
  state          String
  zip            String
  donationAmount  Int?
  sponsorLogoUrl  String?
  status          RegistrationStatus @default(PENDING)
  golfers        Golfer[]
  payments       Payment[]
  createdAt      DateTime           @default(now())

  event   Event   @relation(fields: [eventId], references: [id], onDelete: Restrict)
  package Package @relation(fields: [packageId], references: [id], onDelete: Restrict)

  @@index([eventId])
  @@index([packageId])
  @@index([status])
  @@index([email])
}

model Golfer {
  id             String       @id @default(cuid())
  registrationId String
  name           String
  email          String?

  registration Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([registrationId])
}

model Payment {
  id             String        @id @default(cuid())
  registrationId String?
  donationId     String?
  amount         Int
  provider       String
  providerRef    String
  status         PaymentStatus @default(PENDING)
  createdAt      DateTime      @default(now())

  registration Registration? @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  donation     Donation?     @relation(fields: [donationId], references: [id], onDelete: Cascade)

  @@index([registrationId])
  @@index([donationId])
  @@index([provider])
  @@index([status])
  @@index([providerRef])
}

model Donation {
  id        String         @id @default(cuid())
  name      String
  email     String
  amount    Int
  status    DonationStatus @default(PENDING)
  paidAt    DateTime?
  payments  Payment[]
  createdAt DateTime       @default(now())

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

model GalleryImage {
  id        String          @id @default(cuid())
  category  GalleryCategory
  url       String
  alt       String?
  createdAt DateTime        @default(now())
}
